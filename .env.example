# App
DEBUG=false

# Database (Fly.io Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ksmathtutordb

# Session Cache (Fly.io Redis)
REDIS_URL=redis://localhost:6379

# LLM - set DEFAULT_LLM_PROVIDER to switch providers
# Gemini free tier: 1,000,000 TPM — best free quota for synthetic data generation
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
DEFAULT_LLM_PROVIDER=groq   # "groq" | "anthropic" | "openai" | "gemini" | "cerebras"
DIAGNOSIS_MODE=ml_shadow    # "llm" | "ml_shadow" | "ml_primary"
DIAGNOSIS_MODEL_DIR=data/models/diagnosis
DIAGNOSIS_TAXONOMY_DIR=data/diagnosis_taxonomy
DIAGNOSIS_ML_PRIMARY_MIN_CONFIDENCE=0.62
DIAGNOSIS_BACKGROUND_QUEUE_KEY=diagnosis:bg:queue
DIAGNOSIS_BACKGROUND_RETRY_LIMIT=3
DIAGNOSIS_BACKGROUND_STALE_AFTER_SEC=300
DIAGNOSIS_OVERLAY_AUTO_PROMOTE_THRESHOLD=0.9
DIAGNOSIS_OVERLAY_REVIEW_THRESHOLD=0.75

# Speech
TTS_PROVIDER=polly          # "polly" | "mock"
TTS_VOICE_ID=Joanna
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# CORS
# Prefer FRONTEND_ORIGINS (comma-separated).
FRONTEND_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
# Legacy fallback, used only when FRONTEND_ORIGINS is unset.
FRONTEND_URL=http://localhost:5500
